# === Required ===
JWT_SECRET=change-me-to-a-random-string
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(48))"

# === Environment ===
# ENV=production          # Enforces JWT_SECRET is not default

# === Optional: OpenAI (if not set, uses sentence-transformers locally) ===
# OPENAI_API_KEY=sk-...

# === Optional: Sanity/GROQ integration ===
# SANITY_ENABLED=true
# SANITY_PROJECT_ID=your-project-id
# SANITY_TOKEN=your-sanity-token
# SANITY_DATASET=production

# === Auth ===
# JWT_EXPIRY_MINUTES=60
# MIN_PASSWORD_LENGTH=8

# === CORS ===
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === Upload limits ===
# MAX_UPLOAD_BYTES=52428800    # 50 MB

# === Background jobs ===
# USE_BACKGROUND_JOBS=false

# === Retrieval tuning ===
RETRIEVAL_THRESHOLD=0.20
RETRIEVAL_TOP_K=5
# PASSAGE_TOKEN_SIZE=200
# PASSAGE_OVERLAP=40
